{
  "name": "le-aura-crm-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --watch server.ts --exec \"node --loader ts-node/esm\" server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed:admin": "node --loader ts-node/esm src/seeds/admin.seed.ts",
    "seed:data": "node --loader ts-node/esm src/seeds/data.seed.ts",
    "seed:clean": "node --loader ts-node/esm src/seeds/clean.seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.0",
    "zod": "^3.23.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.20",
    "@types/express-rate-limit": "^6.0.2",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/mongoose": "^5.11.97",
    "@types/node": "^20.12.4",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.4"
  }
}
